# ═══════════════════════════════════════════════════
# VideoForge AI — Environment Variables
# ═══════════════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI Generation
ANTHROPIC_API_KEY=          # Claude — scripts + thumbnails + media queries
ELEVENLABS_API_KEY=         # Narración
OPENAI_API_KEY=             # Whisper — subtítulos con timestamps reales
PEXELS_API_KEY=             # Stock footage para escenas
SHOTSTACK_API_KEY=          # Renderizar MP4 final

# YouTube OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# TikTok OAuth  
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
NEXT_PUBLIC_TIKTOK_CLIENT_KEY=

# Instagram / Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
NEXT_PUBLIC_FACEBOOK_APP_ID=

# App
NEXT_PUBLIC_APP_URL=https://videoforge-ai-rust.vercel.app
CRON_SECRET=
